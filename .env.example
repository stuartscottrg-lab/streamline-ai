# Copy this to .env and fill in your values

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail SMTP (use a Gmail App Password, not your main password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password_here

# Where lead notifications are sent (your personal email)
NOTIFY_EMAIL=you@yourpersonalemail.com

# Your Calendly booking link
CALENDLY_URL=https://calendly.com/your-username/30min

# Simple admin password to view leads at /api/leads?secret=xxx
ADMIN_SECRET=change-this-to-something-random
